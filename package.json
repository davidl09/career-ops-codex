{
  "name": "career-ops",
  "version": "1.0.0",
  "description": "AI-powered job search pipeline for OpenAI Codex with Bun tooling",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "doctor": "bun doctor.mjs",
    "verify": "bun verify-pipeline.mjs",
    "normalize": "bun normalize-statuses.mjs",
    "dedup": "bun dedup-tracker.mjs",
    "merge": "bun merge-tracker.mjs",
    "pdf": "bun generate-pdf.mjs",
    "sync-check": "bun cv-sync-check.mjs",
    "test:all": "bun test-all.mjs",
    "update:check": "bun update-system.mjs check",
    "update": "bun update-system.mjs apply",
    "rollback": "bun update-system.mjs rollback",
    "liveness": "bun check-liveness.mjs"
  },
  "keywords": ["ai", "job-search", "codex", "bun", "career", "automation"],
  "author": "Santiago Fernández de Valderrama <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/santifer/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.58.1"
  }
}
